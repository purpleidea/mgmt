$noop = false
pkg "drbd-utils" {
	state => "installed",

	Meta:autoedge => true,
	Meta:noop => $noop,
}

file "/etc/drbd.conf" {
	content => "this is an mgmt test",
	state => $const.res.file.state.exists,

	Meta:autoedge => true,
	Meta:noop => $noop,

	Before => Svc["drbd"],
	Depend => Pkg["drbd-utils"],
}

file "/etc/drbd.d/" {
	state => $const.res.file.state.exists,

	Meta:autoedge => true,
	Meta:noop => $noop,

	Before => Svc["drbd"],
}

# note that the autoedges between the files and the svc don't exist yet :(
svc "drbd" {
	state => "stopped",

	Meta:autoedge => true,
	Meta:noop => $noop,
}
