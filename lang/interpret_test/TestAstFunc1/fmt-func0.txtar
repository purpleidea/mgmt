-- main.mcl --
func foo($a, $b) { # good
	$a + $b + "\n"
}

func bar( # good
	$a, # also good
	$b,
) {
	$a + $b + "\n"
}

test "foo" {
	comment => foo( # good
		"a",
		"b",
	),
}

test "bar" {
	comment => bar("a", "b"), # good
}
