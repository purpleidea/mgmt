-- main.mcl --
# Create a test file that to serve via HTTP.
$testfile = "/tmp/mgmt-http-autoedge-test.txt"
file $testfile {
    content => "This is a test file for HTTP autoedge testing!",
    state => $const.res.file.state.exists,
}

# Create an HTTP server.
http:server ":8082" {
    address => ":8082",
}

# Serve the test file.
http:file "/test-autoedge" {
    path => $testfile,
    # No manual Depend => File[$testfile] needed - should be automatic
}

# Test with an explicit variable.
$f2 = "/tmp/another-test-file.txt"
file $f2 {
    content => "i'm a cool file in /tmp\n",
    state => $const.res.file.state.exists,
}

http:file "/file2" {
    path => $f2,
  }

-- OUTPUT --
Edge: http:file[/test-autoedge] -> file[/tmp/mgmt-http-autoedge-test.txt] # http:file depends on file
Edge: http:file[/file2] -> file[/tmp/another-test-file.txt] # http:file depends on file
Vertex: file[/tmp/mgmt-http-autoedge-test.txt]
Vertex: file[/tmp/another-test-file.txt]
Vertex: http:file[/test-autoedge]
Vertex: http:file[/file2]
Vertex: http:server[:8082]
