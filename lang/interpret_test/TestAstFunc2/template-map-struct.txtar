-- main.mcl --
import "golang"

$values = {
	"first" => struct{name => "one", value => "alpha"},
	"second" => struct{name => "two", value => "beta"},
}

$out = golang.template("{{ .first.Name }}={{ .first.Value }};{{ .second.Name }}={{ .second.Value }};", $values)

test [$out] {}

-- OUTPUT --
Vertex: test[one=alpha;two=beta;]
